# share-installs - Environment Variables Template
# Copy this file to .env and fill in the values

# --- Domain & Traefik ---
DASHBOARD_DOMAIN=console.share-installs.local
ACME_EMAIL=your-email@example.com

# --- Ports (Dev Only) ---
BACKEND_PORT=6066
DB_PORT=5432
REDIS_PORT=6379

# --- Backend Config ---
# Multi-tenant mode (true/false)
MULTI_TENANT=false
# comma-separated list of allowed origins
CORS_ORIGINS=*
# API Admin Secret (for high-privilege operations)
ADMIN_SECRET=changeme_in_production
# Log Level: error, warn, info, debug, trace
LOG_LEVEL=debug

# --- Security & Auth ---
# JWT Secret for session tokens
JWT_SECRET=generate_a_random_string
# Encryption key for API Keys (must be 32 bytes/char for AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars

# --- OAuth (GitHub) ---
# Register at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# --- Fingerprinting ---
FINGERPRINT_MATCH_THRESHOLD=0.75
FINGERPRINT_MATCH_TTL_HOURS=72
