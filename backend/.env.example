# ============================================================
# share-installs – Backend Environment Variables
#
# Copy this file to .env and fill in values before running.
# NEVER commit .env to version control.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=6066
HOST=0.0.0.0

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/share_installs

# ---- Cache (Redis) ----
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=si:

# ---- Deployment Mode ----
# false (default): self-hosted – user provides their own domain, no API keys needed.
# true:            SaaS        – hosted service, API keys required per project.
MULTI_TENANT=false

# ---- Admin Protection ----
# Protects project management endpoints (POST/GET /v1/projects, API key management).
# Leave empty for fully open access (private network / trusted environment).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# ---- Fingerprint Matching ----
# Max hours a click event is eligible for matching after the user clicks the link.
FINGERPRINT_MATCH_TTL_HOURS=72
# Minimum similarity score to accept a fuzzy match (0.0–1.0).
FINGERPRINT_MATCH_THRESHOLD=0.75

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CORS ----
# Comma-separated list of allowed origins, or * for all.
CORS_ORIGINS=*

# ---- Logging ----
LOG_LEVEL=info
