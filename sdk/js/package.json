{
  "name": "@share-installs/js-sdk",
  "version": "1.0.0",
  "description": "Client-side Web SDK for share-installs – embed in your invite landing page to collect browser fingerprint signals and enable deferred deep link invite attribution",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/umd/share-installs-sdk.min.js",
  "jsdelivr": "dist/umd/share-installs-sdk.min.js",
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json",
    "build:cdn": "rollup -c rollup.config.mjs",
    "build:all": "npm run build && npm run build:cdn",
    "build:watch": "tsc -p tsconfig.esm.json --watch",
    "test": "jest --coverage",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build:all"
  },
  "keywords": [
    "invite",
    "referral",
    "deep-linking",
    "deferred-deep-link",
    "fingerprint",
    "attribution",
    "sdk"
  ],
  "author": "share-installs Authors",
  "license": "Apache-2.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/share-installs/share-installs.git",
    "directory": "sdk/js"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.4",
    "rollup": "^4.60.1",
    "ts-jest": "^29.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  }
}
